# LLM
API_KEY=your_api_key_here
BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.1
LLM_ENABLE_THINKING=false

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=product_scout

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_REVIEWS=product_reviews
MILVUS_COLLECTION_DOCUMENTS=product_documents

# A2A URLs
MARKET_A2A_URL=http://localhost:5101
PROFIT_A2A_URL=http://localhost:5102
SUPPLY_RISK_A2A_URL=http://localhost:5103
REVIEW_A2A_URL=http://localhost:5104

# MCP URLs
MARKET_MCP_URL=http://localhost:8101/mcp
PROFIT_MCP_URL=http://localhost:8102/mcp
SUPPLY_RISK_MCP_URL=http://localhost:8103/mcp
REVIEW_MCP_URL=http://localhost:8104/mcp

# Runtime
API_PORT=8090
FRONTEND_PORT=5173
A2A_TIMEOUT_SECONDS=120
MCP_TIMEOUT_SECONDS=60

# Mock switches
MOCK_LLM=false
MOCK_A2A=false
MOCK_MCP=false
MOCK_MILVUS=false
